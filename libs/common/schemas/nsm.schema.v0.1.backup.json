{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/nsm.schema.v0.2.json",
  "title": "Normalized System Model (NSM) - Graph Schema v0.2",
  "type": "object",
  "required": ["schema_version", "model_id", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2"
    },
    "model_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },

    "provenance": {
      "type": "object",
      "required": ["source", "method", "confidence"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "image_upload, drawio_import, user_input, api_spec, inferred"
        },
        "method": {
          "type": "string",
          "description": "llm_extraction, parser, heuristic, manual"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },

    "trust_boundary": {
      "type": "object",
      "required": ["level", "name"],
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "internet",
            "public_network",
            "private_network",
            "vpc",
            "subnet",
            "cluster",
            "namespace",
            "node",
            "admin_plane",
            "saas",
            "device",
            "unknown"
          ]
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "array",
          "description": "Optional full boundary hierarchy from outermost to innermost",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },

    "asset_type": {
      "type": "string",
      "enum": [
        "photos",
        "tokens",
        "pii",
        "secrets",
        "models",
        "logs",
        "credentials",
        "telemetry",
        "source_code",
        "config",
        "metadata",
        "unknown"
      ]
    },

    "asset_ref": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "$ref": "#/$defs/asset_type"
        },
        "name": {
          "type": "string"
        },
        "sensitivity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical", "unknown"],
          "default": "unknown"
        },
        "direction": {
          "type": "string",
          "enum": ["stores", "processes", "transmits", "receives", "generates", "unknown"],
          "default": "unknown"
        }
      }
    },

    "control_mode": {
      "type": "string",
      "enum": ["preventive", "detective", "corrective", "compensating", "unknown"]
    },

    "control_ref": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "tls",
            "mtls",
            "waf",
            "csp",
            "encryption",
            "rbac",
            "network_policy",
            "admission_policy",
            "rate_limiting",
            "authentication",
            "authorization",
            "logging",
            "monitoring",
            "secret_management",
            "content_scanning",
            "sandboxing",
            "unknown"
          ]
        },
        "mode": {
          "$ref": "#/$defs/control_mode"
        },
        "status": {
          "type": "string",
          "enum": ["present", "assumed", "planned", "missing", "unknown"],
          "default": "unknown"
        },
        "notes": {
          "type": "string"
        }
      }
    },

    "unknown_item": {
      "type": "object",
      "required": ["field", "reason"],
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "question_hint": {
          "type": "string"
        }
      }
    },

    "node_kind": {
      "type": "string",
      "enum": ["object", "identity"]
    },

    "object_type": {
      "type": "string",
      "enum": [
        "service",
        "web_app",
        "mobile_app",
        "api",
        "gateway",
        "load_balancer",
        "pod",
        "container",
        "worker",
        "database",
        "bucket",
        "cache",
        "queue",
        "topic",
        "k8s_cluster",
        "k8s_control_plane",
        "ingress",
        "waf",
        "secret_store",
        "siem",
        "cdn",
        "third_party_saas",
        "llm_runtime",
        "model_provider",
        "unknown"
      ]
    },

    "identity_type": {
      "type": "string",
      "enum": [
        "external_user",
        "internal_user",
        "admin",
        "service_account",
        "workload_identity",
        "third_party",
        "api_client",
        "anonymous",
        "unknown"
      ]
    },

    "node": {
      "type": "object",
      "required": ["id", "kind", "name", "trust_boundary", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/node_kind"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "description": "Must match object_type when kind=object or identity_type when kind=identity"
        },
        "description": {
          "type": "string"
        },
        "trust_boundary": {
          "$ref": "#/$defs/trust_boundary"
        },
        "assets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset_ref"
          },
          "default": []
        },
        "controls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/control_ref"
          },
          "default": []
        },
        "properties": {
          "type": "object",
          "additionalProperties": true,
          "description": "Extensible structured properties: ports, region, public=true, image processing role, etc."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "unknowns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/unknown_item"
          },
          "default": []
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "object" } }
          },
          "then": {
            "properties": {
              "type": { "$ref": "#/$defs/object_type" }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "identity" } }
          },
          "then": {
            "properties": {
              "type": { "$ref": "#/$defs/identity_type" }
            }
          }
        }
      ]
    },

    "protocol_type": {
      "type": "string",
      "enum": [
        "http",
        "https",
        "grpc",
        "tcp",
        "udp",
        "s3",
        "amqp",
        "kafka",
        "sql",
        "dns",
        "filesystem",
        "unknown"
      ]
    },

    "authn_type": {
      "type": "string",
      "enum": [
        "none",
        "password",
        "session_cookie",
        "jwt",
        "oauth2",
        "oidc",
        "api_key",
        "mtls",
        "signed_url",
        "service_account_token",
        "unknown"
      ]
    },

    "edge": {
      "type": "object",
      "required": ["id", "source", "target", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": ["uni", "bi"],
          "default": "uni"
        },
        "protocol": {
          "$ref": "#/$defs/protocol_type",
          "default": "unknown"
        },
        "authn": {
          "$ref": "#/$defs/authn_type",
          "default": "unknown"
        },
        "assets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset_ref"
          },
          "default": []
        },
        "controls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/control_ref"
          },
          "default": []
        },
        "properties": {
          "type": "object",
          "additionalProperties": true,
          "description": "Extensible edge properties: ports, method, path, frequency, volume, etc."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "unknowns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/unknown_item"
          },
          "default": []
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    }
  }
}